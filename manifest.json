{
    "name": "Áudio QR - ASBREMFO",
    "short_name": "ÁudioQR",
    "description": "Compartilhe áudios de alunos via QR Code",
    "start_url": "./index.html",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#000000",
    "orientation": "any",
    "categories": ["education", "utilities"],
    "icons": [
        {
            "src": "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='20' fill='%23000'/%3E%3Ctext y='.9em' font-size='90' x='50' text-anchor='middle' fill='%23fff'%3E🎵%3C/text%3E%3C/svg%3E",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "any"
        }
    ],
    "share_target": {
        "action": "./index.html",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "audio",
                    "accept": [
                        "audio/*",
                        ".opus", ".ogg", ".mp3", ".m4a", ".aac",
                        ".wav", ".wma", ".flac", ".amr", ".3gp"
                    ]
                }
            ]
        }
    },
    "file_handlers": [
        {
            "action": "./index.html",
            "accept": {
                "audio/ogg": [".opus", ".ogg"],
                "audio/opus": [".opus"],
                "audio/mpeg": [".mp3"],
                "audio/mp4": [".m4a"],
                "audio/aac": [".aac"],
                "audio/wav": [".wav"],
                "audio/amr": [".amr"]
            }
        }
    ]
}
