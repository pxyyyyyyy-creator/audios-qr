{
    "name": "Audio QR",
    "short_name": "AudioQR",
    "description": "Share audio via QR Code",
    "start_url": "./index.html",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#000000",
    "orientation": "any",
    "icons": [
        {
            "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23000'/><text y='.9em' font-size='90' x='50' text-anchor='middle' fill='%23fff'>🎵</text></svg>",
            "sizes": "any",
            "type": "image/svg+xml"
        }
    ],
    "share_target": {
        "action": "./index.html",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "audio",
                    "accept": ["audio/ogg", "audio/opus", ".opus", ".ogg"]
                }
            ]
        }
    },
    "file_handlers": [
        {
            "action": "./index.html",
            "accept": {
                "audio/ogg": [".opus", ".ogg"],
                "audio/opus": [".opus", ".ogg"]
            }
        }
    ]
}
